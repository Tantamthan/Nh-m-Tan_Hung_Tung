@page
@model ASCwed.Areas.Identity.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<div class="auth-shell">
    <div class="row margin-bottom-0px">
        <div class="col s12 m10 l8 offset-m1 offset-l2">
            <div class="card auth-card">
                <div class="card-content">
                    <span class="card-title">Access denied</span>
                    <p class="auth-copy">You do not have permission to access this page.</p>
                    <div class="auth-actions">
                        <a href="/" class="btn blue-grey darken-3 waves-effect waves-light">Return home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
