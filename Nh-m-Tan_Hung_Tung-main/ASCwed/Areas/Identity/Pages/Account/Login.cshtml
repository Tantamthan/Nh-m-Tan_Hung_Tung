@page
@model ASCwed.Areas.Identity.Pages.Account.LoginModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    ViewData["Title"] = "Login";
}
<div class="auth-shell">
    <div class="row margin-bottom-0px">
        <div class="col s12 m10 l8 offset-m1 offset-l2">
            <div class="card auth-card">
                <div class="card-content">
                    <span class="card-title">Login</span>
                    <p class="auth-copy">Use your ASC account to access the secure dashboard.</p>
                    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                    {
                        <div class="card-panel green lighten-5 green-text text-darken-4">@Model.StatusMessage</div>
                    }
                    <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
                        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                        <div class="input-field">
                            <input asp-for="Input.Email" autocomplete="username" />
                            <label asp-for="Input.Email"></label>
                            <span asp-validation-for="Input.Email" class="helper-text red-text"></span>
                        </div>
                        <div class="input-field">
                            <input asp-for="Input.Password" autocomplete="current-password" />
                            <label asp-for="Input.Password"></label>
                            <span asp-validation-for="Input.Password" class="helper-text red-text"></span>
                        </div>
                        <p>
                            <label>
                                <input asp-for="Input.RememberMe" type="checkbox" />
                                <span>Remember me</span>
                            </label>
                        </p>
                        <div class="auth-actions">
                            <button type="submit" class="btn blue-grey darken-3 waves-effect waves-light">Login</button>
                            <a asp-page="./ForgotPassword" class="auth-link">Forgot password?</a>
                        </div>
                    </form>

                    <div class="col s12 m4 offset-m1">
                        <h6>Login using External Providers.</h6>
                        <div class="divider"></div>
                        @{
                            var loginProviders = await SignInManager.GetExternalAuthenticationSchemesAsync();
                            if (loginProviders.Count() != 0)
                            {
                                <form asp-area="Identity" asp-page="/Account/ExternalLogin"
                                      asp-route-returnurl="@Model.ReturnUrl"
                                      method="post" class="form-horizontal">
                                    <div>
                                        <p>
                                            @foreach (var provider in loginProviders)
                                            {
                                                <button type="submit" class="btn btn-default"
                                                        name="provider" value="@provider.DisplayName"
                                                        title="Log in using your @provider.DisplayName account">
                                                    @provider.DisplayName
                                                </button>
                                            }
                                        </p>
                                    </div>
                                </form>
                            }
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}