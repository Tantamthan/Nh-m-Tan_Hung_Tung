@page
@model ASCwed.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-shell">
    <div class="row margin-bottom-0px">
        <div class="col s12 m10 l8 offset-m1 offset-l2">
            <div class="card auth-card">
                <div class="card-content">
                    <span class="card-title">Forgot Password</span>
                    <p class="auth-copy">Enter your email address and we will send you a password reset link.</p>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                        <div class="input-field">
                            <input asp-for="Input.Email" autocomplete="username" />
                            <label asp-for="Input.Email"></label>
                            <span asp-validation-for="Input.Email" class="helper-text red-text"></span>
                        </div>

                        <div class="auth-actions">
                            <button type="submit" class="btn blue-grey darken-3 waves-effect waves-light">Send reset link</button>
                            <a asp-page="./Login" class="auth-link">Back to login</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
