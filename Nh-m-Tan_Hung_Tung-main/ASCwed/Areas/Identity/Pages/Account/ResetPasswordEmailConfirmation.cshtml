@page
@model ASCwed.Areas.Identity.Pages.Account.ResetPasswordEmailConfirmationModel
@{
    ViewData["Title"] = "Reset Password Email Confirmation";
}

<div class="auth-shell">
    <div class="row margin-bottom-0px">
        <div class="col s12 m10 l8 offset-m1 offset-l2">
            <div class="card auth-card">
                <div class="card-content">
                    <span class="card-title">Check your email</span>
                    <p class="auth-copy">
                        A reset-password link has been sent to
                        <strong>@Model.Email</strong>.
                    </p>
                    <p>Please open the email and click the link to continue resetting your password.</p>
                    <div class="auth-actions">
                        <a asp-page="./Login" class="btn blue-grey darken-3 waves-effect waves-light">Back to login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
