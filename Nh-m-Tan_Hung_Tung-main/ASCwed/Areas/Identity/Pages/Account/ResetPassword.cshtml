@page
@model ASCwed.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-shell">
    <div class="row margin-bottom-0px">
        <div class="col s12 m10 l8 offset-m1 offset-l2">
            <div class="card auth-card">
                <div class="card-content">
                    <span class="card-title">Reset Password</span>
                    <p class="auth-copy">Enter and confirm your new password.</p>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                        <input asp-for="Input.Code" type="hidden" />
                        <input asp-for="Input.Email" type="hidden" />

                        <div class="input-field">
                            <input asp-for="Input.Password" autocomplete="new-password" />
                            <label asp-for="Input.Password"></label>
                            <span asp-validation-for="Input.Password" class="helper-text red-text"></span>
                        </div>

                        <div class="input-field">
                            <input asp-for="Input.ConfirmPassword" autocomplete="new-password" />
                            <label asp-for="Input.ConfirmPassword"></label>
                            <span asp-validation-for="Input.ConfirmPassword" class="helper-text red-text"></span>
                        </div>

                        <div class="auth-actions">
                            <button type="submit" class="btn blue-grey darken-3 waves-effect waves-light">Reset password</button>
                            <a asp-page="./Login" class="auth-link">Back to login</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
