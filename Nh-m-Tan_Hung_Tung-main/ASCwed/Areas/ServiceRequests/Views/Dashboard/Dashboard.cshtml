@{
    ViewData["Title"] = "Dashboard";
}

<div class="section">
    <div class="row">
        <div class="col s12">
            <div class="card panel-card">
                <div class="card-content">
                    <span class="card-title">Dashboard</span>
                    <p>Welcome to the Automobile Service Center dashboard.</p>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col s12 m4">
            <div class="card stat-card stat-card-blue">
                <div class="card-content white-text">
                    <span class="card-title">Service Requests</span>
                    <p class="flow-text">0</p>
                    <p>No active requests yet.</p>
                </div>
            </div>
        </div>
        <div class="col s12 m4">
            <div class="card stat-card stat-card-green">
                <div class="card-content white-text">
                    <span class="card-title">Customers</span>
                    <p class="flow-text">0</p>
                    <p>No customer statistics loaded.</p>
                </div>
            </div>
        </div>
        <div class="col s12 m4">
            <div class="card stat-card stat-card-amber">
                <div class="card-content white-text">
                    <span class="card-title">Notifications</span>
                    <p class="flow-text">0</p>
                    <p>No pending notifications.</p>
                </div>
            </div>
        </div>
    </div>
</div>
