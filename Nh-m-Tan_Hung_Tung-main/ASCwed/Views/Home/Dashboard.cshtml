@{
    Layout = "_SecureLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="section">
    <div class="row">
        <div class="col s12">
            <h4 class="blue-grey-text">Dashboard</h4>
            <p class="grey-text">Welcome to the Automobile Service Center management portal.</p>
        </div>
    </div>
    <div class="row">
        <div class="col s12 m4">
            <div class="card blue-grey darken-1">
                <div class="card-content white-text">
                    <span class="card-title"><i class="material-icons left">perm_data_setting</i>Service Requests</span>
                    <p class="flow-text">0</p>
                    <p>Active service requests</p>
                </div>
                <div class="card-action">
                    <a href="#" class="white-text">View All</a>
                </div>
            </div>
        </div>
        <div class="col s12 m4">
            <div class="card teal">
                <div class="card-content white-text">
                    <span class="card-title"><i class="material-icons left">supervisor_account</i>Customers</span>
                    <p class="flow-text">0</p>
                    <p>Registered customers</p>
                </div>
                <div class="card-action">
                    <a href="#" class="white-text">View All</a>
                </div>
            </div>
        </div>
        <div class="col s12 m4">
            <div class="card orange darken-2">
                <div class="card-content white-text">
                    <span class="card-title"><i class="material-icons left">message</i>Notifications</span>
                    <p class="flow-text">0</p>
                    <p>Pending notifications</p>
                </div>
                <div class="card-action">
                    <a href="#" class="white-text">View All</a>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col s12">
            <div class="card">
                <div class="card-content">
                    <span class="card-title">Recent Activity</span>
                    <p class="grey-text">No recent activity to display.</p>
                </div>
            </div>
        </div>
    </div>
</div>